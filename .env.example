# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and must never be committed.

# MongoDB connection string (Atlas or local).
# The database name "matir-poshra" is set in code (src/lib/mongodb.ts).
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"

# Secret used to sign HMAC session cookies. Use a long random string.
AUTH_SECRET="change-me-to-a-long-random-secret"
